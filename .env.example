OPENROUTER_API_KEY=KEY_HERE
# Optional Docker host port (default in docker-compose.yml is 18000)
# BOARDROOM_HOST_PORT=18000
# Optional: Fernet key (url-safe base64) for encrypted ~/.boardroom store when keyring is unavailable
# BOARDROOM_CREDENTIAL_KEY=
# Optional: Tavily API key when config web_search.provider is tavily (provider must be ddgs or tavily)
# TAVILY_API_KEY=
